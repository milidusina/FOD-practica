{Realizar un programa que presente un menú con opciones para:
a. Crear un archivo binario de registros no ordenados de empleados y completarlo con
		datos ingresados desde teclado. De cada empleado se registra: número de empleado,
		apellido, nombre, edad y DNI. Algunos empleados pueden ingresan el DNI con valor 0, lo
		que significa que al momento de la carga puede no tenerlo. La carga finaliza cuando se
		ingresa el String ‘fin’ como apellido.
b. Abrir el archivo anteriormente generado y
	i. Listar en pantalla los datos de empleados que tengan un nombre o apellido
		determinado, el cual se proporciona desde el teclado.
	ii. Listar en pantalla los empleados de a uno por línea.
	iii. Listar en pantalla los empleados mayores de 70 años, próximos a jubilarse.
NOTA: El nombre del archivo a crear o utilizar debe ser proporcionado por el usuario.}

program ejer3;
const
	FIN = 'fin';
type   
			empleado = record
				num_emp:integer;
				nombre: string;
				apellido: string;
				dni: integer;
				edad:integer;
            end;
    archivo_empleados = file of empleado;
    
procedure LeerEmp (var emp:empleado);
begin
	writeln('ingrese el apellido del empleado:   ');
	readln(emp.apellido);
	if (emp.apellido<>FIN) then
		begin
			writeln('ingrese el nombre:   ');
			readln(emp.nombre);
			writeln('ingrese el numero de empleado:   ');
			readln(emp.num_emp);
			writeln('ingrese el dni:   ');
			readln(emp.dni);
			writeln('ingrese la edad:   ');
			readln(emp.edad);
		end;
end;
    
procedure CargarArchivo (var arch:archivo_empleados);
var
	emp: empleado;
begin
	reset(arch);
	seek(arch, filesize(arch));
	LeerEmp (emp);
	while (emp.apellido <> FIN) do
		begin
			write(arch,emp);
			LeerEmp(emp);
		end;
	close(arch);
end;
    
procedure MostrarEmp (e:empleado);
begin
	writeln ('empleado:  ', e.nombre, '  ', e.apellido, ', edad ', e.edad, ', numero de empleado ', e.num_emp, ', dni ', e.dni);
end;
    
procedure RecorrerImprimir (var arch:archivo_empleados; nom_ape:string);    //INCISO i
var
	emp: empleado;
begin
	reset(arch);
	writeln;
	writeln ('el dato ingresado coincidio con:   ');
	while not eof (arch) do
		begin
			read(arch,emp);
			if (emp.nombre = nom_ape) or (emp.apellido = nom_ape)  then  
				MostrarEmp(emp);
		end;
	writeln;
	close(arch);
end; 
 
 procedure Imprimir (var arch: archivo_empleados);   //INCISO ii
 var
	e: empleado;
begin
	reset(arch);	
	writeln;
	writeln('LISTADO DE TODOS LOS EMPLEADOS: ');
	while not eof (arch) do 
		begin
			read(arch,e);
			MostrarEmp(e);
		end;
	writeln;
	close(arch);
end;
 
 procedure ImprimirCasiJubilados (var arch: archivo_empleados);  // INCISO iii
 var
	emp: empleado;
 begin
	reset(arch);
	writeln('Estos son los empleados proximos a jubilarse:   ');
	while not eof (arch) do
		begin
			read(arch,emp);
			if (emp.edad > 70) then 
				MostrarEmp(emp);
		end;
	writeln;
	close(arch);
 end;
 
 
var
	arch_empleados: archivo_empleados;
	nombre_path:string;
	nom_ape: string;
begin
     write('ingrese el nombre del archivo:     ');
     readln(nombre_path);
     assign(arch_empleados, nombre_path);   
     rewrite(arch_empleados);
     
	CargarArchivo(arch_empleados);	
	writeln('Ingrese un nombre o apellido para buscar datos de empleados que coincidan:    ');
	readln(nom_ape);
	RecorrerImprimir(arch_empleados,nom_ape); //inciso A
	Imprimir(arch_empleados); //inciso B
	ImprimirCasiJubilados(arch_empleados); //inciso C
	
	close(arch_empleados);
end.
