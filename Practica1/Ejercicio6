					writeln('Ingrese el codigo del celular a modificar stock');
					readln(cod);
					reset(arch)
					while (not eof (arch)) and ( <> ) do begin
						while(cod <> celu.codigo) do begin
							read(arch,celu);
						end;
					end;
				end;
			7:  begin
			
				end;
				
				
	until (opcion=0)
end.
