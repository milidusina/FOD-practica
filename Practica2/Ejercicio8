{Se desea gestionar la información correspondiente al consumo de yerba mate en las distintas provincias
de la Argentina.
4
Para ello, se dispone de un archivo maestro que contiene la siguiente información: código de provincia,
nombre de la provincia, cantidad de habitantes y cantidad total histórica de kilos de yerba consumidos.
Mensualmente, se reciben 16 archivos detalle con información relevada sobre el consumo de yerba mate
en distintos puntos del país. Cada archivo detalle contiene: código de provincia y cantidad de kilos de yerba
consumidos en ese relevamiento.
Un archivo detalle puede contener información correspondiente a una o varias provincias, y una misma
provincia puede aparecer cero, uno o más veces en los distintos archivos detalle.
Tanto el archivo maestro como los archivos detalle están ordenados por código de provincia.
Se solicita desarrollar un programa que actualice el archivo maestro a partir de la nueva información de
consumo.
Además, se debe informar por pantalla aquellas provincias (código y nombre) cuya cantidad total histórica
de yerba consumida supere los 10.000 kilos, indicando también el promedio de consumo por habitante.
Para este informe deben considerarse tanto las provincias actualizadas como aquellas que no hayan
recibido modificaciones.
Nota: Cada archivo debe recorrerse una única vez}

program ejer8;
const
	dimF = 16;
	valor_alto = 9999;
type
	rangoVector = 1..dimF;
	info_mae = record
		cod_prov : integer;
		nombre_prov : String;
		cant_habitantes : integer;
		cant_consumida_total : integer;
	end;
	
	info_det = record
		cod_prov: integer;
		cant_consumida : integer;
	end;
	
	archivo_maestro = File of info_mae;
	archivo_detalle = File of info_det;
	vector_detalles = array[rangoVector] of archivo_detalle;
	vector_consumos = array [rangoVector] of info_det;
	
	
	
	
	
//-------------------------PROCEDURE--------------------------
procedure leerDetalle (var det: archivo_detalle;
										var consumo: info_det);
begin
	if (not eof(det)) then		
		read(det,consumo)
	else
		consumo.cod_prov := valor_alto;
end;

procedure leerMae (var mae: archivo_maestro; var consumo: info_mae) ;
begin
	if (not eof (mae)) then
		read (mae,consumo)
	else
		consumo.cod_prov := valor_alto;
end;


procedure inicializarDetalles (var vector: vector_detalles; var vec_consumos: vector_consumos);
		var
			i: integer;
			nombre : string;
		begin
			for i := 1 to dimF do 
				begin
					writeln('Ingrese el nombre del archivo numero:  ', i);
					readln(nombre);
					assign (vector[i], nombre);
					reset(vector[i]);
					leerDetalle(vector[i],vec_consumos[i]);
				end;
		end;
//------


procedure cerrarDetalles (var vector: vector_detalles);
		var
			i: integer;
		begin
			for i := 1 to dimF do 
				begin
					close(vector[i]);
				end;
		end;
//------

procedure minimo (var vector: vector_detalles; var vec_consumos: vector_consumos; var min: info_det);
	var
		pos, i: integer;
	begin
		min.cod_prov := valor_alto;
		for i := 1 to dimF do begin
			if (vec_consumos[i].cod_prov < min.cod_prov) then begin
				min := vec_consumos[i];
				pos := i;
			end;
		end;
		if (min.cod_prov <> valor_alto) then
			leerDetalle (vector[pos],vec_consumos[pos]);
	end;

//-----
procedure imprimirPromedio (regM: info_mae);
var
	promedio : real;
begin
	writeln(' La cantidad consumida historica de yerba de la provincia  ', regM.nombre_prov , '  es mayor a 10.000 kilos' );
	promedio := regM.cant_consumida_total / regM.cant_habitantes;
	writeln('El promedio  de consumo por habitante es de  ', promedio );
end;

//-----

procedure actualizarArchivoMaestro (var mae: archivo_maestro; var vector: vector_detalles);
var
	vec_consumos : vector_consumos;
	regM: info_mae;
	min: info_det;
	cant : integer;
	actual : info_det;
begin
	reset (mae);
	inicializarDetalles(vector,vec_consumos);
	leerMae(mae,regM);
	minimo (vector, vec_consumos,min);
	actual := min;
	while (regM.cod_prov <> valor_alto) do begin  //el maestro manda, xq tenemos q procesar si o si a todos sus registros, nos piden q informemos
			cant := 0;                                                        //las prov q tiene cant historica mayor a 10.000,  sin importar si se actualizaron o no
			while (actual.cod_prov <> valor_alto)  and  (actual.cod_prov = min.cod_prov) do begin
					cant := cant + min.cant_consumida;	
					minimo (vector, vec_consumos,min);
			end;
			while (regM.cod_prov <> actual.cod_prov) do begin
					if (regM.cant_consumida_total > 10.000) then
						imprimirPromedio(regM);
					LeerMae(mae,regM);
			end;
			regM.cant_consumida_total := regM.cant_consumida_total  + cant;
			if (regM.cant_consumida_total > 10.000) then 
				imprimirPromedio(regM);
			seek (mae, filePos(mae)-1);
			write(mae,regM);
		end;
	close(mae);
	cerrarDetalles(vector);
end;

//---------------------------MAIN----------------------------

var
	vector : vector_detalles;
	mae: archivo_maestro;
begin
	actualizarArchivoMaestro(mae,vector);
	
End.
